void doGenerateReport(QWidget* parent, QTableWidget* table){
    QString id = selectedCell(table,0);
    if(id.isEmpty()){ warn(parent,"Select a criminal first."); return; }
    int idx = findCriminal(id.toStdString());
    if(idx==-1){ warn(parent,"Criminal not found."); return; }
    int evCount=0, wiCount=0, viCount=0;
    string caseStatus="No Case", verdict="N/A", caseIDFound="";
    for(auto& a: activeCases) if(a.getLinkedCriminalID()==id.toStdString()){caseStatus="Active";caseIDFound=a.getCaseID();}
    for(auto& c: closedCases) if(c.getLinkedCriminalID()==id.toStdString()){caseStatus="Closed";verdict=c.getVerdict();caseIDFound=c.getCaseID();}
    for(auto& e: evidences) if(e.getLinkedCriminalID()==id.toStdString()) evCount++;
    for(auto& w: witnesses) if(w.getLinkedCriminalID()==id.toStdString()) wiCount++;
    for(auto& v: victims) if(v.getLinkedCriminalID()==id.toStdString()) viCount++;
    QString report = QString(
                         "Name: %1\nAge: %2\nCNIC: %3\nAddress: %4\nCrime Type: %5\nThreat Level: %6\n"
                         "Case ID: %7\nCase Status: %8\nVerdict: %9\nBail Status: %10\n"
                         "Evidence: %11 item(s)\nWitnesses: %12\nVictims: %13")
                         .arg(QString::fromStdString(criminals[idx].getName()))
                         .arg(criminals[idx].getAge())
                         .arg(QString::fromStdString(criminals[idx].getCnic()))
                         .arg(QString::fromStdString(criminals[idx].getAddress()))
                         .arg(QString::fromStdString(criminals[idx].getCrimeType()))
                         .arg(QString::fromStdString(criminals[idx].getThreatLvl()))
                         .arg(QString::fromStdString(caseIDFound))
                         .arg(QString::fromStdString(caseStatus))
                         .arg(QString::fromStdString(verdict))
                         .arg(QString::fromStdString(criminals[idx].getBailStatus()))
                         .arg(evCount).arg(wiCount).arg(viCount);
    QMessageBox::information(parent, "Criminal Report", report);
}

QWidget* buildStatsWidget(){
    QWidget* w = new QWidget();
    QGridLayout* g = new QGridLayout(w);
    auto addStat = [&](int row,int col,const QString& label,int value){
        QLabel* l = new QLabel(label);
        QLabel* v = new QLabel(QString::number(value));
        v->setProperty("class","statValue");
        QVBoxLayout* box = new QVBoxLayout();
        box->addWidget(v); box->addWidget(l);
        QFrame* card = new QFrame(); card->setProperty("class","statCard");
        card->setLayout(box);
        g->addWidget(card,row,col);
    };
    int mostWanted=0,high=0,medium=0,low=0,onBail=0;
    for(auto& c: criminals){
        string t=c.getThreatLvl();
        if(t=="MOST WANTED") mostWanted++;
        else if(t=="HIGH") high++;
        else if(t=="MEDIUM") medium++;
        else low++;
        if(c.getBailStatus()=="On Bail") onBail++;
    }
    addStat(0,0,"Total Criminals",(int)criminals.size());
    addStat(0,1,"Most Wanted",mostWanted);
    addStat(0,2,"High Threat",high);
    addStat(0,3,"On Bail",onBail);
    addStat(1,0,"Active Cases",(int)activeCases.size());
    addStat(1,1,"Closed Cases",(int)closedCases.size());
    addStat(1,2,"Total Evidence",(int)evidences.size());
    addStat(1,3,"Total Witnesses",(int)witnesses.size());
    addStat(2,0,"Total Victims",(int)victims.size());
    addStat(2,1,"Total Officers",(int)officers.size());
    addStat(2,2,"Total Detectives",(int)detectives.size());
    addStat(2,3,"Total Meetings",(int)meetings.size());
    return w;
}

QWidget* buildSearchTab(){
    QWidget* w = new QWidget();
    QVBoxLayout* lay = new QVBoxLayout(w);
    lay->addWidget(new QLabel("Search & Filter Criminals"));
    QHBoxLayout* row = new QHBoxLayout();
    QComboBox* mode = new QComboBox();
    mode->addItems({"By Name","By Criminal ID","By Threat Level","By Crime Type"});
    QLineEdit* input = new QLineEdit();
    QPushButton* btn = new QPushButton("Search");
    row->addWidget(mode); row->addWidget(input); row->addWidget(btn);
    lay->addLayout(row);
    QTableWidget* table = makeTable({"ID","Name","Age","CNIC","Address","Crime Type","Threat Level","Bail Status"});
    lay->addWidget(table);
    QObject::connect(btn, &QPushButton::clicked, [=](){
        QString q = input->text().trimmed();
        table->setRowCount(0);
        int row=0;
        for(auto& c: criminals){
            bool match=false;
            QString m = mode->currentText();
            if(m=="By Name") match = QString::fromStdString(toUpperStr(c.getName())).contains(q.toUpper());
            else if(m=="By Criminal ID") match = QString::fromStdString(c.getCriminalID())==q;
            else if(m=="By Threat Level") match = QString::fromStdString(toUpperStr(c.getThreatLvl()))==q.toUpper();
            else if(m=="By Crime Type") match = QString::fromStdString(toUpperStr(c.getCrimeType())).contains(q.toUpper());
            if(match){
                table->insertRow(row);
                setRow(table,row,{QString::fromStdString(c.getCriminalID()),QString::fromStdString(c.getName()),
                                    QString::number(c.getAge()),QString::fromStdString(c.getCnic()),
                                    QString::fromStdString(c.getAddress()),QString::fromStdString(c.getCrimeType()),
                                    QString::fromStdString(c.getThreatLvl()),QString::fromStdString(c.getBailStatus())});
                row++;
            }
        }
        if(row==0) warn(w,"No records found.");
    });
    return w;
}

