    QObject::connect(backBtn, &QPushButton::clicked, [](){ goTo(buildWelcomePage()); });
    QObject::connect(loginBtn, &QPushButton::clicked, [w,user,pass](){
        string u = user->text().toStdString(), p = pass->text().toStdString();
        for(auto& d: detectives){
            if(d.getUsername()==u && d.getPassword()==p){
                goTo(buildDetectiveDashboard(u, d.getName()));
                return;
            }
        }
        warn(w,"Invalid credentials.");
    });
    return w;
}

