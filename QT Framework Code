QTableWidget* makeTable(const QStringList& headers){
    QTableWidget* t = new QTableWidget();
    t->setColumnCount(headers.size());
    t->setHorizontalHeaderLabels(headers);
    t->horizontalHeader()->setStretchLastSection(true);
    t->setEditTriggers(QAbstractItemView::NoEditTriggers);
    t->setSelectionBehavior(QAbstractItemView::SelectRows);
    t->setSelectionMode(QAbstractItemView::SingleSelection);
    t->setAlternatingRowColors(true);
    return t;
}

void setRow(QTableWidget* t, int row, const QStringList& vals){
    for(int i=0;i<vals.size();i++) t->setItem(row,i,new QTableWidgetItem(vals[i]));
}

// Generic text-field form dialog. Returns empty list if cancelled.
QStringList getFormInput(QWidget* parent, const QString& title, const QStringList& labels, const QStringList& initial = QStringList()){
    QDialog dlg(parent);
    dlg.setWindowTitle(title);
    dlg.setMinimumWidth(380);
    QVBoxLayout* outer = new QVBoxLayout(&dlg);
    QFormLayout* form = new QFormLayout();
    QList<QLineEdit*> edits;
    for(int i=0;i<labels.size();i++){
        QLineEdit* e = new QLineEdit();
        if(i < initial.size()) e->setText(initial[i]);
        form->addRow(labels[i]+":", e);
        edits.push_back(e);
    }
    outer->addLayout(form);
    QDialogButtonBox* box = new QDialogButtonBox(QDialogButtonBox::Ok | QDialogButtonBox::Cancel);
    outer->addWidget(box);
    QObject::connect(box, &QDialogButtonBox::accepted, &dlg, &QDialog::accept);
    QObject::connect(box, &QDialogButtonBox::rejected, &dlg, &QDialog::reject);

    while(true){
        if(dlg.exec() != QDialog::Accepted) return QStringList();
        bool ok = true;
        for(auto* e : edits) if(e->text().trimmed().isEmpty()) ok = false;
        if(ok){
            QStringList result;
            for(auto* e : edits) result << e->text().trimmed();
            return result;
        }
        QMessageBox::warning(parent, "Missing fields", "Please fill in all fields.");
    }
}

// Dialog with a combobox of choices, returns selected text or "" if cancelled.
QString getChoiceDialog(QWidget* parent, const QString& title, const QString& label, const QStringList& choices, const QString& current=""){
    QDialog dlg(parent);
    dlg.setWindowTitle(title);
    QVBoxLayout* outer = new QVBoxLayout(&dlg);
    QFormLayout* form = new QFormLayout();
    QComboBox* combo = new QComboBox();
    combo->addItems(choices);
    if(!current.isEmpty()){
        int idx = combo->findText(current);
        if(idx>=0) combo->setCurrentIndex(idx);
    }
    form->addRow(label, combo);
    outer->addLayout(form);
    QDialogButtonBox* box = new QDialogButtonBox(QDialogButtonBox::Ok | QDialogButtonBox::Cancel);
    outer->addWidget(box);
    QObject::connect(box, &QDialogButtonBox::accepted, &dlg, &QDialog::accept);
    QObject::connect(box, &QDialogButtonBox::rejected, &dlg, &QDialog::reject);
    if(dlg.exec() != QDialog::Accepted) return "";
    return combo->currentText();
}

void info(QWidget* p, const QString& msg){ QMessageBox::information(p, "Success", msg); }
void warn(QWidget* p, const QString& msg){ QMessageBox::warning(p, "Notice", msg); }

// Generic module tab builder
QWidget* makeModuleTab(const QString& heading, const QStringList& headers,
                       std::function<void(QTableWidget*)> refresh,
                       const std::vector<std::pair<QString, std::function<void(QTableWidget*)>>>& actions){
    QWidget* w = new QWidget();
    QVBoxLayout* lay = new QVBoxLayout(w);
    QLabel* h = new QLabel(heading);
    h->setProperty("class","sectionHeading");
    lay->addWidget(h);
    QTableWidget* table = makeTable(headers);
    refresh(table);
    lay->addWidget(table);
    QHBoxLayout* btnRow = new QHBoxLayout();
    for(auto& act : actions){
        QPushButton* b = new QPushButton(act.first);
        QObject::connect(b, &QPushButton::clicked, [table, fn=act.second](){ fn(table); });
        btnRow->addWidget(b);
    }
    btnRow->addStretch();
    lay->addLayout(btnRow);
    return w;
}

QString selectedCell(QTableWidget* t, int col){
    int row = t->currentRow();
    if(row < 0) return "";
    QTableWidgetItem* it = t->item(row, col);
    return it ? it->text() : "";
}

