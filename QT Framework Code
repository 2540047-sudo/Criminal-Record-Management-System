    string getUsername(){return username;} void setUsername(string u){username=u;}
    string getPassword(){return password;} void setPassword(string p){password=p;}
    string getBadgeNo(){return badgeNo;} void setBadgeNo(string b){badgeNo=b;}
    string getDepartment(){return department;} void setDepartment(string d){department=d;}
    string getRank(){return rank;} void setRank(string r){rank=r;}
};

class Detective : public Person {
    string detectiveID,username,password,specialization; int caseLoad;
public:
