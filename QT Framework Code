string toUpperStr(string s) {
    for (int i = 0; i < (int)s.length(); i++) s[i] = toupper(s[i]);
    return s;
}

string intToStr(int n) { stringstream ss; ss << n; return ss.str(); }

string todayStr() { return QDate::currentDate().toString("yyyy-MM-dd").toStdString(); }

