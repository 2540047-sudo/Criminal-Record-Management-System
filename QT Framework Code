void doAddCriminal(QWidget* parent){
    QStringList vals = getFormInput(parent, "Add Criminal", {"Name","Age","CNIC","Address","Crime Type"});
    if(vals.isEmpty()) return;
    QString threat = getChoiceDialog(parent, "Threat Level", "Threat Level", {"LOW","MEDIUM","HIGH","MOST WANTED"});
    if(threat.isEmpty()) return;
    string id = genCriminalID();
    Criminal c(id, vals[0].toStdString(), vals[1].toInt(), vals[2].toStdString(), vals[3].toStdString(), vals[4].toStdString(), threat.toStdString());
    criminals.push_back(c);
    saveCriminals();
    if(threat=="MOST WANTED"){
        string nid = genNotifID();
        string msg = "ALERT: " + c.getName() + " is MOST WANTED - " + c.getCrimeType();
        notifications.push_back(Notification(nid, msg, id, c.getName(), "MOST WANTED", todayStr()));
        saveNotifications();
        warn(parent, QString::fromStdString(msg));
    }
    info(parent, "Criminal added! ID: " + QString::fromStdString(id));
}

void doUpdateCriminal(QWidget* parent, QTableWidget* table){
    QString id = selectedCell(table,0);
    if(id.isEmpty()){ warn(parent,"Select a criminal from the table first."); return; }
    int idx = findCriminal(id.toStdString());
    if(idx==-1){ warn(parent,"Criminal not found."); return; }
    QString field = getChoiceDialog(parent,"Update Criminal","Field to update", {"Name","Age","Address","Crime Type","Threat Level"});
    if(field.isEmpty()) return;
    if(field=="Name"){
        QStringList v = getFormInput(parent,"Update Name",{"New Name"},{QString::fromStdString(criminals[idx].getName())});
        if(!v.isEmpty()) criminals[idx].setName(v[0].toStdString());
    } else if(field=="Age"){
        QStringList v = getFormInput(parent,"Update Age",{"New Age"},{QString::number(criminals[idx].getAge())});
        if(!v.isEmpty()) criminals[idx].setAge(v[0].toInt());
    } else if(field=="Address"){
        QStringList v = getFormInput(parent,"Update Address",{"New Address"},{QString::fromStdString(criminals[idx].getAddress())});
        if(!v.isEmpty()) criminals[idx].setAddress(v[0].toStdString());
    } else if(field=="Crime Type"){
        QStringList v = getFormInput(parent,"Update Crime Type",{"New Crime Type"},{QString::fromStdString(criminals[idx].getCrimeType())});
        if(!v.isEmpty()) criminals[idx].setCrimeType(v[0].toStdString());
    } else if(field=="Threat Level"){
        QString t = getChoiceDialog(parent,"Threat Level","New Threat Level",{"LOW","MEDIUM","HIGH","MOST WANTED"}, QString::fromStdString(criminals[idx].getThreatLvl()));
        if(!t.isEmpty()){
            criminals[idx].setThreatLvl(t.toStdString());
            if(t=="MOST WANTED"){
                string nid=genNotifID();
                string msg="ALERT: "+criminals[idx].getName()+" updated to MOST WANTED!";
                notifications.push_back(Notification(nid,msg,id.toStdString(),criminals[idx].getName(),"MOST WANTED",todayStr()));
                saveNotifications();
                warn(parent, QString::fromStdString(msg));
            }
        }
    }
    saveCriminals();
    info(parent,"Criminal updated!");
}

void doDeleteCriminal(QWidget* parent, QTableWidget* table){
    QString id = selectedCell(table,0);
    if(id.isEmpty()){ warn(parent,"Select a criminal from the table first."); return; }
    int idx = findCriminal(id.toStdString());
    if(idx==-1){ warn(parent,"Criminal not found."); return; }
    auto reply = QMessageBox::question(parent,"Confirm Delete","Delete "+QString::fromStdString(criminals[idx].getName())+" and all linked active cases?");
    if(reply != QMessageBox::Yes) return;
    criminals.erase(criminals.begin()+idx);
    saveCriminals();
    for(int i=(int)activeCases.size()-1;i>=0;i--)
        if(activeCases[i].getLinkedCriminalID()==id.toStdString()) activeCases.erase(activeCases.begin()+i);
    saveActiveCases();
    info(parent,"Criminal and linked cases deleted.");
}

